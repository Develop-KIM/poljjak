# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...           # Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Settings → API → service_role (서버 전용)

# Drizzle (Supabase Postgres 직접 연결)
# Settings → Database → Connection string → URI (Direct connection)
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# CLOVA Studio (HyperCLOVA X)
CLOVA_STUDIO_API_KEY=
CLOVA_STUDIO_API_URL=https://clovastudio.stream.naver.com/testapp/v3/chat-completions/HCX-005

# App
NUXT_PUBLIC_APP_URL=http://localhost:3000
